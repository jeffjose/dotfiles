# Read by npm, pnpm and aube (mise's npm: backend reads its settings from here).
#
# aube refuses to install packages under `lowDownloadThreshold` (default 1000)
# weekly downloads as a typosquat guard, which blocks our own low-traffic
# published packages -- `mise install npm:t-get` dies with
# ERR_AUBE_LOW_DOWNLOAD_PACKAGE. Exempt those by name rather than setting
# lowDownloadThreshold=0, which would disable the guard for everything.
#
# The OSV MAL-* advisory check is separate and still applies to these.
#
# npm itself warns "Unknown user config" about this key -- harmless, it is an
# aube setting and npm has no equivalent.
allowedUnpopularPackages=t-get
